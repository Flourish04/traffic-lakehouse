FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    procps netcat-openbsd \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

COPY agent/requirements.txt .
RUN pip install --no-cache-dir -r agent/requirements.txt

COPY protobuf/ ./protobuf/
COPY agent/ ./agent/

RUN sed -i 's/^import monitoring_pb2/from protobuf import monitoring_pb2/' protobuf/monitoring_pb2_grpc.py && \
    python -c "from protobuf import monitoring_pb2, monitoring_pb2_grpc"

ENV GRPC_SERVER_HOST=${COMPUTE_HOST:-localhost}
ENV GRPC_SERVER_PORT=${AGENT_GRPC_PORT:-50051}
ENV COLLECTION_INTERVAL=5
ENV AGENT_HOSTNAME=

EXPOSE 50051

CMD ["python", "agent/agent.py"]
