# ============================================================
# MONITORING STACK - Environment Configuration
# ============================================================

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password_here

# Prometheus NiFi Token (managed by monitoring/scripts/refresh_nifi_token.sh)
# The script reads NIFI_USER and NIFI_PASS from environment
NIFI_URL=https://localhost:8443
NIFI_USER=admin
NIFI_PASS=your_nifi_password_here
TOKEN_FILE=/tmp/nifi_token
