# ============================================================
# COMPUTE NODE - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.compute.example .env
# ============================================================

# ─── Storage Node (SeaweedFS) ───────────────────────────────
# IP address of the Storage VPS where SeaweedFS is running
STORAGE_HOST=192.168.10.2

# ─── Compute Node ───────────────────────────────────────────
# Public hostname/IP of this compute VPS (for Kafka public listener)
COMPUTE_PUBLIC_HOST=your-compute-vps-public-ip

# ─── Kafka ──────────────────────────────────────────────────
# VPN port for Kafka (default: 9092)
KAFKA_VPN_PORT=9092
# Public internet port for Kafka (default: 9094)
KAFKA_PUBLIC_PORT=9094
# Kafka UI web port
KAFKA_UI_PORT=8080

# ─── PostgreSQL (Iceberg Catalog Metadata) ──────────────────
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=iceberg

# ─── S3 / SeaweedFS Credentials ─────────────────────────────
# Must match the credentials configured in SeaweedFS s3.json
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1

# ─── Trino ──────────────────────────────────────────────────
# Port for Trino query engine (default: 8085)
TRINO_PORT=8085

# ─── NiFi JWT Token Refresh ─────────────────────────────────
# User credentials for NiFi API access (used by monitoring/scripts/refresh_nifi_token.sh)
# NOTE: This script should be updated to use environment variables instead of hardcoded values
NIFI_URL=https://localhost:8443
NIFI_USER=admin
NIFI_PASS=your_nifi_password_here
