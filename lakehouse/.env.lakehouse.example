# ============================================================
# LAKEHOUSE / STORAGE NODE - Environment Configuration
# Copy this file to .env.lakehouse and fill in your values:
#   cp .env.lakehouse.example .env.lakehouse
# ============================================================

# S3 credentials for SeaweedFS S3-compatible API
# These MUST match the values in lakehouse/s3.json
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# NOTE: lakehouse/s3.json must be created separately
# with the same credentials configured in SeaweedFS
